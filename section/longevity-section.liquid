{% schema %}
{
  "name": "Longevity Section",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Blue Zone Lifestyle"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Pure Sardinian Essence"
    },
    {
      "type": "textarea",
      "id": "paragraph_1",
      "label": "Paragraph 1",
      "default": "Vitablu is your trusted source for pure, authentic Sardinian products like extra virgin olive oil and hand-harvested sea salt."
    },
    {
      "type": "textarea",
      "id": "paragraph_2",
      "label": "Paragraph 2",
      "default": "Inspired by the timeless health benefits of the Mediterranean diet and Sardinia’s tradition of longevity, our carefully curated selection of nutrition-rich ingredients nourishes both body and soul."
    },
    {
      "type": "text",
      "id": "highlight",
      "label": "Highlight Quote",
      "default": "Experience the essence of Sardinia in every bite. Taste the tradition, live the legacy."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Discover Our Products"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "video_url_cdn",
      "label": "Shopify Video URL (CDN)",
      "default": "https://cdn.shopify.com/videos/c/o/v/7479b1193e6c4bf4acf451befd73e775.mp4"
    }
  ],
  "presets": [
    {
      "name": "Longevity Section"
    }
  ]
}
{% endschema %}

<section class="longevity-section">
  <div class="longevity-grid">
    
    <div class="longevity-content">
      <span class="longevity-subtitle">{{ section.settings.subtitle }}</span>
      <h2>{{ section.settings.title }}</h2>
      
      <p>{{ section.settings.paragraph_1 }}</p>
      <p>{{ section.settings.paragraph_2 }}</p>

      <div class="longevity-highlight">
        "{{ section.settings.highlight }}"
      </div>

      {% if section.settings.button_link != blank %}
        <a href="{{ section.settings.button_link }}" class="longevity-btn">
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    </div>

    <div class="longevity-media">
      {% if section.settings.video_url_cdn != blank %}
      <div class="longevity-video">
        <div class="longevity-video-inner">
          <video 
            class="longevity-video-element" 
            autoplay 
            muted 
            loop 
            playsinline
            preload="auto">
            <source src="{{ section.settings.video_url_cdn }}" type="video/mp4">
            Tu navegador no soporta videos.
          </video>
        </div>
      </div>
      {% endif %}
    </div>
  </div>
</section>

<style>
:root {
    --vita-blue: #1A3C5A;
    --olive-green: #6B705C;
    --sand-light: #F9F8F6;
    --text-dark: #2D3032;
    --text-light: #5A5D60;
}

.longevity-section {
    height: 100vh;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0 clamp(40px, 8vw, 140px);
    background-color: var(--sand-light);
    background-image: radial-gradient(circle at 10% 20%, rgba(26, 60, 90, 0.03) 0%, transparent 50%);
    font-family: 'Lato', sans-serif;
}

.longevity-grid {
    max-width: 1200px;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 80px;
    align-items: center;
}

.longevity-content {
    max-width: 520px;
}

.longevity-subtitle {
    font-size: 0.75rem; 
    letter-spacing: 3px; 
    text-transform: uppercase;
    color: var(--olive-green);
    display: block;
    margin-bottom: 20px;
    font-weight: 400; 
}

.longevity-content h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2.4rem; 
    line-height: 1.3;
    font-weight: 400; 
    margin-bottom: 25px;
    color: var(--vita-blue);
    letter-spacing: 0px; 
}

.longevity-content p {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--text-light);
    margin-bottom: 20px;
    font-weight: 300;
}

.longevity-highlight {
    margin-top: 40px;
    padding-left: 20px;
    border-left: 1px solid var(--olive-green); 
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 1.1rem; 
    font-weight: 400;
    color: var(--text-dark);
    line-height: 1.7;
}

.longevity-btn {
    display: inline-block;
    margin-top: 40px;
    padding: 14px 30px; 
    background-color: var(--vita-blue);
    color: white;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 0.75rem;
    font-weight: 400;
    border-radius: 50px;
    transition: all 0.3s ease;
}

.longevity-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.15);
}

.longevity-video {
    width: 100%;
    border-radius: 30px;
    overflow: hidden;
    box-shadow: 0 30px 60px rgba(0,0,0,0.2);
}

.longevity-video-inner {
    aspect-ratio: 16/10;
    position: relative;
    background: #000;
}

/* ESTILO PARA EL VIDEO MP4 */
.longevity-video-element {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover; 
}

@media (max-width: 900px) {
    .longevity-section {
        height: auto;
        padding: 80px 30px;
    }

    .longevity-grid {
        grid-template-columns: 1fr;
        gap: 60px;
    }

    .longevity-content {
        max-width: 100%;
    }

    .longevity-content h2 {
        font-size: 1.9rem; 
    }
}
</style>
