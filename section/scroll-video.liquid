<section class="scroll-video-section">

  <div class="video-sticky">

    <!-- SECUENCIA DE FRAMES -->
    <img
      id="scrollFrames"
      src="https://cdn.shopify.com/s/files/1/0773/2776/1630/files/frame_0001_0.00s.png?v=1774021473"
      alt="Vitablu animation"
      width="1920"
      height="1080"
    >

    <!-- IMAGEN FINAL -->
    <img
      id="endImage"
      src="https://cdn.shopify.com/s/files/1/0773/2776/1630/files/PATTERN_VITABLU_VERDE.jpg?v=1772729319"
      alt="Vitablu Pattern"
      width="2048"
      height="1463"
    />

    <!-- CARRUSEL -->
    <div class="carousel-overlay" id="carouselOverlay">

      <button class="carousel-arrow carousel-arrow--left" id="carouselPrev">
        ‹
      </button>

      <div class="carousel-track-wrapper">
        <div class="carousel-track" id="carouselTrack">

          <div class="carousel-item">
            <video autoplay muted loop playsinline>
              <source src="https://cdn.shopify.com/videos/c/o/v/bb5c559b94ca455dac2178ec24770581.mov" type="video/mp4">
            </video>
          </div>

          <div class="carousel-item">
            <img src="https://cdn.shopify.com/s/files/1/0773/2776/1630/files/IMG_3814_jpg.jpg?v=1772730788" />
          </div>

          <div class="carousel-item">
            <video autoplay muted loop playsinline>
              <source src="https://cdn.shopify.com/videos/c/o/v/94ca8d7a1c464654890ec3bf83eecb8e.mov" type="video/mp4">
            </video>
          </div>

          <div class="carousel-item">
            <img src="https://cdn.shopify.com/s/files/1/0773/2776/1630/files/IMG_3880_jpg.jpg?v=1772730788" />
          </div>

          <div class="carousel-item">
            <video autoplay muted loop playsinline>
              <source src="https://cdn.shopify.com/videos/c/o/v/f433ecf8217c43599fda81dff51a7117.mov" type="video/mp4">
            </video>
          </div>

          <div class="carousel-item">
            <img src="https://cdn.shopify.com/s/files/1/0773/2776/1630/files/20250919_VitaBlu_Product_Photography-069.jpg?v=1772730796" />
          </div>

        </div>
      </div>

      <button class="carousel-arrow carousel-arrow--right" id="carouselNext">
        ›
      </button>

    </div>

  </div>

</section>

<style>

.scroll-video-section{
height:300vh;
position:relative;
}

.video-sticky{
position:sticky;
top:0;
height:100vh;
overflow:hidden;
}

#scrollFrames{
width:100%;
height:100%;
object-fit:cover;
position:absolute;
top:0;
left:0;
}

#endImage{
position:absolute;
top:0;
left:0;
width:100%;
height:100%;
object-fit:cover;
opacity:0;
transition:opacity .3s linear;
pointer-events:none;
z-index:1;
}

.carousel-overlay{
position:absolute;
bottom:48px;
left:0;
right:0;
z-index:10;
display:flex;
align-items:center;
gap:12px;
padding:0 20px;
opacity:0;
transform:translateY(16px);
transition:opacity .4s ease,transform .4s ease;
pointer-events:none;
}

.carousel-overlay.visible{
opacity:1;
transform:translateY(0);
pointer-events:all;
}

.carousel-track-wrapper{
flex:1;
overflow:hidden;
border-radius:12px;
}

.carousel-track{
display:flex;
gap:12px;
transition:transform .45s cubic-bezier(.25,.46,.45,.94);
}

.carousel-item{
flex:0 0 calc(25% - 9px);
aspect-ratio:9/16;
border-radius:10px;
overflow:hidden;
background:#111;
}

.carousel-item img,
.carousel-item video{
width:100%;
height:100%;
object-fit:cover;
}

.carousel-arrow{
width:40px;
height:40px;
border-radius:50%;
border:none;
background:rgba(255,255,255,.2);
color:#fff;
cursor:pointer;
}

</style>

<script>

document.addEventListener("DOMContentLoaded",function(){

const frameImage=document.getElementById("scrollFrames");
const section=document.querySelector(".scroll-video-section");
const endImage=document.getElementById("endImage");
const carousel=document.getElementById("carouselOverlay");

const frames = [
  "https://cdn.shopify.com/s/files/1/0773/2776/1630/files/frame_0001_0.00s_fa776f97-0340-4213-8701-f03e86275f86.png?v=1774025627",
  "https://cdn.shopify.com/s/files/1/0773/2776/1630/files/frame_0002_0.30s.png?v=1774025627",
  "https://cdn.shopify.com/s/files/1/0773/2776/1630/files/frame_0003_0.60s.png?v=1774025627",
  "https://cdn.shopify.com/s/files/1/0773/2776/1630/files/frame_0004_0.90s.png?v=1774025627",
  "https://cdn.shopify.com/s/files/1/0773/2776/1630/files/frame_0005_1.20s.png?v=1774025627",
  "https://cdn.shopify.com/s/files/1/0773/2776/1630/files/frame_0006_1.50s.png?v=1774025627",
  "https://cdn.shopify.com/s/files/1/0773/2776/1630/files/frame_0007_1.80s.png?v=1774025626",
  "https://cdn.shopify.com/s/files/1/0773/2776/1630/files/frame_0008_2.10s.png?v=1774025626",
  "https://cdn.shopify.com/s/files/1/0773/2776/1630/files/frame_0009_2.40s.png?v=1774025626",
  "https://cdn.shopify.com/s/files/1/0773/2776/1630/files/frame_0010_2.70s.png?v=1774025627",
  "https://cdn.shopify.com/s/files/1/0773/2776/1630/files/frame_0011_3.00s.png?v=1774025626",
  "https://cdn.shopify.com/s/files/1/0773/2776/1630/files/frame_0012_3.30s.png?v=1774025626",
  "https://cdn.shopify.com/s/files/1/0773/2776/1630/files/frame_0013_3.60s.png?v=1774025626",
  "https://cdn.shopify.com/s/files/1/0773/2776/1630/files/frame_0014_3.90s.png?v=1774025626",
  "https://cdn.shopify.com/s/files/1/0773/2776/1630/files/frame_0015_4.20s.png?v=1774025626",
  "https://cdn.shopify.com/s/files/1/0773/2776/1630/files/frame_0016_4.50s.png?v=1774025626",
  "https://cdn.shopify.com/s/files/1/0773/2776/1630/files/frame_0017_4.80s.png?v=1774025626",
  "https://cdn.shopify.com/s/files/1/0773/2776/1630/files/frame_0018_5.10s.png?v=1774025626",
  "https://cdn.shopify.com/s/files/1/0773/2776/1630/files/frame_0019_5.40s.png?v=1774025626",
  "https://cdn.shopify.com/s/files/1/0773/2776/1630/files/frame_0020_5.70s.png?v=1774025626"
];

const frameCount = frames.length;

/* precarga */
frames.forEach(src=>{
const img=new Image();
img.src=src;
});

/* scroll */
function updateFrames(){

const rect=section.getBoundingClientRect();
const sectionHeight=section.offsetHeight-window.innerHeight;
const scrolled=-rect.top;

const progress=scrolled/sectionHeight;
const clamped=Math.max(0,Math.min(progress,1));

const frameIndex=Math.min(
  frameCount - 1,
  Math.floor(clamped * frameCount)
);

frameImage.src=frames[frameIndex];

/* imagen final */
const fadeStart=.85;

if(clamped>fadeStart){

const fadeProgress=(clamped-fadeStart)/(1-fadeStart);
endImage.style.opacity=fadeProgress;

if(fadeProgress>.3){
carousel.classList.add("visible");
}else{
carousel.classList.remove("visible");
}

}else{
endImage.style.opacity=0;
carousel.classList.remove("visible");
}

}

window.addEventListener("scroll",updateFrames,{passive:true});

});

</script>

{% schema %}
{
"name":"Scroll Video",
"presets":[
{
"name":"Scroll Video"
}
]
}
{% endschema %}
