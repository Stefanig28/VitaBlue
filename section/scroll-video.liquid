<section class="scroll-video-section">

  <div class="video-sticky">

    <!-- SECUENCIA DE FRAMES -->
    <img
      id="scrollFrames"
      src="https://cdn.shopify.com/s/files/1/0773/2776/1630/files/ezgif-frame-001.jpg?v=1773089354"
      alt="Vitablu animation"
      width="1920"
      height="1080"
    >

    <!-- IMAGEN FINAL -->
    <img
      id="endImage"
      src="https://cdn.shopify.com/s/files/1/0773/2776/1630/files/PATTERN_VITABLU_VERDE.jpg?v=1772729319"
      alt="Vitablu Pattern"
      width="2048"
      height="1463"
    />

    <!-- CARRUSEL -->
    <div class="carousel-overlay" id="carouselOverlay">

      <button class="carousel-arrow carousel-arrow--left" id="carouselPrev" aria-label="Anterior">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <div class="carousel-track-wrapper">
        <div class="carousel-track" id="carouselTrack">

          <div class="carousel-item">
            <video autoplay muted loop playsinline>
              <source src="https://cdn.shopify.com/videos/c/o/v/bb5c559b94ca455dac2178ec24770581.mov" type="video/mp4">
            </video>
          </div>

          <div class="carousel-item">
            <img src="https://cdn.shopify.com/s/files/1/0773/2776/1630/files/IMG_3814_jpg.jpg?v=1772730788" alt="Vitablu Pattern" width="5712" height="4284" />
          </div>

          <div class="carousel-item">
            <video autoplay muted loop playsinline>
              <source src="https://cdn.shopify.com/videos/c/o/v/94ca8d7a1c464654890ec3bf83eecb8e.mov" type="video/mp4">
            </video>
          </div>

          <div class="carousel-item">
            <img src="https://cdn.shopify.com/s/files/1/0773/2776/1630/files/IMG_3880_jpg.jpg?v=1772730788" alt="Vitablu Pattern" width="5678" height="4259" />
          </div>

          <div class="carousel-item">
            <video autoplay muted loop playsinline>
              <source src="https://cdn.shopify.com/videos/c/o/v/f433ecf8217c43599fda81dff51a7117.mov" type="video/mp4">
            </video>
          </div>

          <div class="carousel-item">
            <img src="https://cdn.shopify.com/s/files/1/0773/2776/1630/files/20250919_VitaBlu_Product_Photography-069.jpg?v=1772730796" alt="Vitablu Pattern" width="6016" height="4016" />
          </div>

        </div>
      </div>

      <button class="carousel-arrow carousel-arrow--right" id="carouselNext" aria-label="Siguiente">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>

    </div>

  </div>

</section>

<style>

/* SECCIÓN */
.scroll-video-section{
height:300vh;
position:relative;
}

.video-sticky{
position:sticky;
top:0;
height:100vh;
overflow:hidden;
}

/* FRAMES */
.video-sticky #scrollFrames{
width:100%;
height:100%;
object-fit:cover;
position:absolute;
top:0;
left:0;
}

/* IMAGEN FINAL */
#endImage{
position:absolute;
top:0;
left:0;
width:100%;
height:100%;
object-fit:cover;
opacity:0;
transition:opacity .3s linear;
pointer-events:none;
z-index:1;
}

/* CARRUSEL */
.carousel-overlay{
position:absolute;
bottom:48px;
left:0;
right:0;
z-index:10;
display:flex;
align-items:center;
gap:12px;
padding:0 20px;
opacity:0;
transform:translateY(16px);
transition:opacity .4s ease,transform .4s ease;
pointer-events:none;
}

.carousel-overlay.visible{
opacity:1;
transform:translateY(0);
pointer-events:all;
}

.carousel-track-wrapper{
flex:1;
overflow:hidden;
border-radius:12px;
}

.carousel-track{
display:flex;
gap:12px;
transition:transform .45s cubic-bezier(.25,.46,.45,.94);
will-change:transform;
}

.carousel-item{
position:relative;
flex:0 0 calc(25% - 9px);
aspect-ratio:9/16;
border-radius:10px;
overflow:hidden;
background:#111;
box-shadow:0 8px 32px rgba(0,0,0,.45);
cursor:pointer;
transition:transform .25s ease,box-shadow .25s ease;
}

.carousel-item:hover{
transform:scale(1.03);
box-shadow:0 12px 40px rgba(0,0,0,.6);
}

.carousel-item img,
.carousel-item video{
width:100%;
height:100%;
object-fit:cover;
display:block;
}

.carousel-arrow{
flex-shrink:0;
width:40px;
height:40px;
border-radius:50%;
border:none;
background:rgba(255,255,255,.18);
backdrop-filter:blur(8px);
color:#fff;
display:flex;
align-items:center;
justify-content:center;
cursor:pointer;
transition:background .2s ease,transform .2s ease;
z-index:2;
}

.carousel-arrow:hover{
background:rgba(255,255,255,.35);
transform:scale(1.1);
}

.carousel-arrow:disabled{
opacity:.3;
cursor:default;
transform:none;
}

@media (max-width:768px){

.carousel-item{
flex:0 0 calc(50% - 6px);
}

.carousel-overlay{
bottom:24px;
padding:0 12px;
gap:8px;
}

.carousel-arrow{
width:34px;
height:34px;
}

}

@media (max-width:480px){

.carousel-item{
flex:0 0 calc(72% - 6px);
}

}

</style>

<script>

document.addEventListener("DOMContentLoaded",function(){

const frameImage=document.getElementById("scrollFrames");
const section=document.querySelector(".scroll-video-section");
const endImage=document.getElementById("endImage");
const carousel=document.getElementById("carouselOverlay");

const track=document.getElementById("carouselTrack");
const btnPrev=document.getElementById("carouselPrev");
const btnNext=document.getElementById("carouselNext");

/* FRAMES */

const frameCount=54;

const frames=[];

for(let i=1;i<=frameCount;i++){

const num=String(i).padStart(3,"0");

frames.push(
`https://cdn.shopify.com/s/files/1/0773/2776/1630/files/ezgif-frame-${num}.jpg?v=1773089354`
);

}

/* precargar */

frames.forEach(src=>{
const img=new Image();
img.src=src;
});

/* scroll */

function updateFrames(){

const rect=section.getBoundingClientRect();

const sectionHeight=section.offsetHeight-window.innerHeight;

const scrolled=-rect.top;

const progress=scrolled/sectionHeight;

const clamped=Math.max(0,Math.min(progress,1));

const frameIndex=Math.floor(clamped*(frameCount-1));

frameImage.src=frames[frameIndex];

/* imagen final */

const fadeStart=.85;

if(clamped>fadeStart){

const fadeProgress=(clamped-fadeStart)/(1-fadeStart);

endImage.style.opacity=fadeProgress;

if(fadeProgress>.3){

carousel.classList.add("visible");

}else{

carousel.classList.remove("visible");

}

}else{

endImage.style.opacity=0;
carousel.classList.remove("visible");

}

}

window.addEventListener("scroll",updateFrames,{passive:true});

/* carrusel */

let currentIndex=0;

function getVisibleCount(){

if(window.innerWidth<=480)return 1.4;
if(window.innerWidth<=768)return 2;
return 4;

}

function updateArrows(){

const items=track.querySelectorAll(".carousel-item");
const visible=Math.floor(getVisibleCount());
const maxIndex=Math.max(0,items.length-visible);

btnPrev.disabled=currentIndex<=0;
btnNext.disabled=currentIndex>=maxIndex;

}

function getItemWidth(){

const item=track.querySelector(".carousel-item");
if(!item)return 0;

const gap=12;

return item.offsetWidth+gap;

}

function goTo(index){

const items=track.querySelectorAll(".carousel-item");
const visible=Math.floor(getVisibleCount());
const max=Math.max(0,items.length-visible);

currentIndex=Math.max(0,Math.min(index,max));

track.style.transform=`translateX(-${currentIndex*getItemWidth()}px)`;

updateArrows();

}

btnPrev.addEventListener("click",()=>goTo(currentIndex-1));
btnNext.addEventListener("click",()=>goTo(currentIndex+1));

window.addEventListener("resize",()=>goTo(currentIndex),{passive:true});

updateArrows();

});

</script>

{% schema %}
{
"name":"Scroll Video",
"presets":[
{
"name":"Scroll Video"
}
]
}
{% endschema %}
