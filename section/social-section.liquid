<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:wght@400;600&display=swap" rel="stylesheet">

<style>
#insta-section {
    font-family: 'Montserrat', sans-serif;
    width: 100%;
    max-width: 100%;
    margin: 60px 0;
    box-sizing: border-box;
    overflow: hidden;
}

.insta-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 40px;
    margin-bottom: 24px;
}

.insta-header h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 4rem;
    font-weight: 400;
    letter-spacing: 2px;
    color: #000;
    margin: 0;
    line-height: 1;
}

.insta-follow-btn {
    display: inline-block;
    background: #111;
    color: #fff;
    text-decoration: none;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    padding: 14px 28px;
    border-radius: 50px;
    letter-spacing: 0.5px;
    transition: background 0.2s ease, transform 0.2s ease;
    white-space: nowrap;
}

.insta-follow-btn:hover {
    background: #333;
    transform: scale(1.03);
}

/* Scrolling track */
.insta-track-outer {
    width: 100%;
    overflow: hidden;
    cursor: grab;
}

.insta-track-outer:active {
    cursor: grabbing;
}

.insta-track {
    display: flex;
    gap: 16px;
    width: max-content;
    animation: scrollLeft 80s linear infinite;
    padding: 0 40px;
}

.insta-track:hover,
.insta-track.paused {
    animation-play-state: paused;
}

@keyframes scrollLeft {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
}

.insta-card {
    flex: 0 0 auto;
    width: 220px;
    border-radius: 18px;
    overflow: hidden;
    background: #000;
    box-shadow: 0 6px 20px rgba(0,0,0,0.12);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.insta-card:hover {
    transform: scale(1.03);
    box-shadow: 0 12px 35px rgba(0,0,0,0.22);
}

.insta-video-box {
    position: relative;
    width: 100%;
    padding-top: 177.77%;
    overflow: hidden;
    background: #000;
}

.insta-video-box iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    pointer-events: none;
}
</style>

